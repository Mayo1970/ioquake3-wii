/*
 * ioquake3-wii: input/wii_input.c — unified auto-detecting input backend
 *
 * Controller priority (re-evaluated every frame):
 *   1. Wiimote + Nunchuk   (WPAD_EXP_NUNCHUK)
 *   2. Wiimote + Classic   (WPAD_EXP_CLASSIC) — GameCube-style layout
 *   3. GameCube PAD port 0 (fallback when no Wiimote+extension is found)
 *
 * Bare Wiimote (no extension) is treated the same as no Wiimote → GC fallback.
 *
 * ── Wiimote + Nunchuk (Wiimote held normally, pointing at screen) ──────────
 *
 * GAME mode (Key_GetCatcher() == 0):
 *   IR pointer       → SE_MOUSE camera aim (delta, IR_SENSITIVITY_F scale)
 *   Nunchuk stick    → 'w'/'s'/'a'/'d'
 *   Nunchuk C        → 'c' (crouch)
 *   Nunchuk Z        → K_MOUSE2 (secondary fire / zoom)
 *   Wiimote B        → K_MOUSE1 (primary fire)
 *   Wiimote A        → K_SPACE  (jump)
 *   Wiimote 1        → ']' (next weapon)
 *   Wiimote 2        → '[' (prev weapon)
 *   Wiimote D-pad UP → K_ENTER  (use item)
 *   Wiimote +        → K_ESCAPE (open menu)
 *   Wiimote HOME     → quit to homebrew (main loop)
 *
 * MENU mode (Key_GetCatcher() != 0):
 *   Nunchuk stick    → SE_MOUSE cursor
 *   Wiimote D-pad    → K_UPARROW / K_DOWNARROW / K_LEFTARROW / K_RIGHTARROW
 *   Wiimote A        → K_MOUSE1  (select / click)
 *   Wiimote B        → K_ESCAPE  (back)
 *   Wiimote +        → K_ESCAPE
 *   Wiimote HOME     → quit to homebrew
 *
 * ── Classic Controller / GameCube (identical layout) ──────────────────────
 *
 * GAME mode:
 *   Left stick / D-pad → 'w'/'s'/'a'/'d'
 *   Right stick / C-stick → SE_MOUSE camera (LOOK_SENSITIVITY_F = 5.0)
 *   A → K_SPACE (jump)   B → 'c' (crouch)
 *   X → ']' (next weapon)   Y → '[' (prev weapon)
 *   Right trigger (R/ZR/FULL_R) → K_MOUSE1 (fire)
 *   Left trigger  (L/ZL/FULL_L) → K_MOUSE2 (secondary fire)
 *   Z / ZR → K_ENTER (use item)   Start / + → K_ESCAPE
 *
 * MENU mode:
 *   Both sticks → SE_MOUSE cursor
 *   D-pad → K_UPARROW / K_DOWNARROW / K_LEFTARROW / K_RIGHTARROW
 *   A / Z → K_MOUSE1 (select)   B / Start / + → K_ESCAPE
 *   Y → K_CONSOLE
 */

#include <gccore.h>
#include <wiiuse/wpad.h>
#include <ogc/pad.h>
#include <math.h>
#include <string.h>
#include <stdio.h>

#include "wii_input.h"
#include "qcommon/q_shared.h"
#include "qcommon/qcommon.h"
#include "keycodes.h"

extern int Key_GetCatcher(void);

/* ─── Configuration ────────────────────────────────────────────────────── */
#define STICK_DEADZONE_MAG  0.15f    /* joystick dead zone (mag 0..1 scale)    */
#define STICK_SENSITIVITY_F  3.0f   /* menu cursor sensitivity (joystick→px)  */
#define LOOK_SENSITIVITY_F   5.0f   /* camera look sensitivity (right/C-stick) */
#define IR_SENSITIVITY_F     2.0f   /* IR pixel delta → Q3 mouse units scale  */
#define IR_MAX_DELTA        40      /* per-frame IR delta clamp (prevents snap) */

/* GameCube raw stick constants */
#define GC_DEADZONE         20      /* dead zone: raw s8 -127..127 range       */
#define TRIGGER_THRESHOLD  100      /* GC analog trigger digital threshold 0-255 */
#define GC_PORT             PAD_CHAN0

#ifndef M_PI
#define M_PI 3.14159265358979323846
#endif

/* ─── State ─────────────────────────────────────────────────────────────── */
typedef enum { CTRL_NONE, CTRL_WIIMOTE_NUNCHUK, CTRL_CLASSIC, CTRL_GAMECUBE } ctrl_type_t;

static qboolean    s_key_held[512];
static ctrl_type_t s_ctrl_type  = CTRL_NONE;
static qboolean    s_in_game    = qfalse;
static qboolean    s_home_pressed = qfalse;

/* Float accumulators for sub-pixel carry-over */
static float s_cursor_ax = 0.0f, s_cursor_ay = 0.0f; /* menu cursor  */
static float s_look_ax   = 0.0f, s_look_ay   = 0.0f; /* camera (GC/Classic) */
static float s_ir_ax     = 0.0f, s_ir_ay     = 0.0f; /* IR fractional carry */

/* IR delta tracking */
static int      s_ir_prev_x     = 0, s_ir_prev_y = 0;
static qboolean s_ir_prev_valid = qfalse;

/* ─── Generic helpers ───────────────────────────────────────────────────── */

static void InjectKey(int key, qboolean down)
{
    if (s_key_held[key] == down) return;
    s_key_held[key] = down;
    Com_QueueEvent(0, SE_KEY, key, down, 0, NULL);
}

static void ReleaseAllKeys(void)
{
    int i;
    for (i = 0; i < 512; i++) {
        if (s_key_held[i]) {
            s_key_held[i] = qfalse;
            Com_QueueEvent(0, SE_KEY, i, qfalse, 0, NULL);
        }
    }
    s_cursor_ax = s_cursor_ay = 0.0f;
    s_look_ax   = s_look_ay   = 0.0f;
    s_ir_ax     = s_ir_ay     = 0.0f;
    s_ir_prev_valid = qfalse;
}

/* Float accumulator → SE_MOUSE.  Q3: +y = down; joystick +y = up → negate. */
static void EmitMouseAccum(float dx, float dy, float *ax, float *ay)
{
    *ax += dx;
    *ay += dy;
    int ox = (int)*ax, oy = (int)*ay;
    *ax -= (float)ox;
    *ay -= (float)oy;
    if (ox || oy)
        Com_QueueEvent(0, SE_MOUSE, ox, -oy, 0, NULL);
}

/*
 * Joystick (calibrated polar: mag 0..1, ang degrees 0=up/90=right) →
 * SE_MOUSE with sensitivity and dead zone.
 */
static void InjectJsMouse(joystick_t *js, float sens, float *ax, float *ay)
{
    if (js->mag < STICK_DEADZONE_MAG) { *ax = *ay = 0.0f; return; }
    float rad = (float)(js->ang * (M_PI / 180.0));
    float x = js->mag * sinf(rad);  /* +x = right  */
    float y = js->mag * cosf(rad);  /* +y = up/forward */
    EmitMouseAccum(x * sens, y * sens, ax, ay);
}

/*
 * Joystick → WASD keys.
 * mag/ang: mag 0..1, ang 0=up, 90=right, 180=down, 270=left.
 * Allows simultaneous diagonals (e.g. W+D when pushing up-right).
 */
static void InjectJsWASD(joystick_t *js)
{
    if (js->mag < STICK_DEADZONE_MAG) {
        InjectKey('w', qfalse); InjectKey('s', qfalse);
        InjectKey('d', qfalse); InjectKey('a', qfalse);
        return;
    }
    float rad = (float)(js->ang * (M_PI / 180.0));
    float x = js->mag * sinf(rad);
    float y = js->mag * cosf(rad);
    InjectKey('w', y >  STICK_DEADZONE_MAG ? qtrue : qfalse);
    InjectKey('s', y < -STICK_DEADZONE_MAG ? qtrue : qfalse);
    InjectKey('d', x >  STICK_DEADZONE_MAG ? qtrue : qfalse);
    InjectKey('a', x < -STICK_DEADZONE_MAG ? qtrue : qfalse);
}

/* GC raw s8 stick (-127..127) → SE_MOUSE with dead zone and sensitivity. */
static void InjectGcStickMouse(s8 x, s8 y, float sens, float *ax, float *ay)
{
    int ix = (int)x, iy = (int)y;
    if (ix > -GC_DEADZONE && ix < GC_DEADZONE) ix = 0;
    if (iy > -GC_DEADZONE && iy < GC_DEADZONE) iy = 0;
    if (ix == 0 && iy == 0) { *ax = *ay = 0.0f; return; }
    EmitMouseAccum((float)ix / 127.0f * sens, (float)iy / 127.0f * sens, ax, ay);
}

/* GC raw s8 stick → WASD keys. */
static void InjectGcStickWASD(s8 x, s8 y)
{
    InjectKey('w', (int)y >  GC_DEADZONE ? qtrue : qfalse);
    InjectKey('s', (int)y < -GC_DEADZONE ? qtrue : qfalse);
    InjectKey('d', (int)x >  GC_DEADZONE ? qtrue : qfalse);
    InjectKey('a', (int)x < -GC_DEADZONE ? qtrue : qfalse);
}

/* ─── IR mouselook (delta model — Wiimote pointing at screen) ────────────── */
static void InjectIR(WPADData *d)
{
    if (!d->ir.valid) {
        s_ir_prev_valid = qfalse;
        return;
    }
    int cx = (int)d->ir.x, cy = (int)d->ir.y;
    if (s_ir_prev_valid) {
        int rdx = cx - s_ir_prev_x;
        int rdy = cy - s_ir_prev_y;
        /* Clamp to prevent large snap when IR re-acquires after going off-screen */
        if (rdx >  IR_MAX_DELTA) rdx =  IR_MAX_DELTA;
        if (rdx < -IR_MAX_DELTA) rdx = -IR_MAX_DELTA;
        if (rdy >  IR_MAX_DELTA) rdy =  IR_MAX_DELTA;
        if (rdy < -IR_MAX_DELTA) rdy = -IR_MAX_DELTA;
        /* IR: positive x = right, positive y = down → no y-negate needed here */
        float fx = (float)rdx * IR_SENSITIVITY_F;
        float fy = (float)rdy * IR_SENSITIVITY_F;
        s_ir_ax += fx; s_ir_ay += fy;
        int ox = (int)s_ir_ax, oy = (int)s_ir_ay;
        s_ir_ax -= (float)ox; s_ir_ay -= (float)oy;
        if (ox || oy)
            Com_QueueEvent(0, SE_MOUSE, ox, oy, 0, NULL);
    }
    s_ir_prev_x = cx;
    s_ir_prev_y = cy;
    s_ir_prev_valid = qtrue;
}

/* ─── Wiimote + Nunchuk handler ─────────────────────────────────────────── */
static void ProcessWiimoteNunchuk(WPADData *d, qboolean in_game)
{
    u32 held = WPAD_ButtonsHeld(WPAD_CHAN_0);

    /* HOME always triggers quit, regardless of mode */
    if (held & WPAD_BUTTON_HOME)
        s_home_pressed = qtrue;

    if (in_game) {
        /* ── Game mode ─────────────────────────────────────── */
        InjectKey(K_MOUSE1, (held & WPAD_BUTTON_B)    ? qtrue : qfalse);
        InjectKey(K_SPACE,  (held & WPAD_BUTTON_A)    ? qtrue : qfalse);
        InjectKey(']',      (held & WPAD_BUTTON_1)    ? qtrue : qfalse);
        InjectKey('[',      (held & WPAD_BUTTON_2)    ? qtrue : qfalse);
        InjectKey(K_ENTER,  (held & WPAD_BUTTON_UP)   ? qtrue : qfalse);
        InjectKey(K_ESCAPE, (held & WPAD_BUTTON_PLUS) ? qtrue : qfalse);

        /* Nunchuk buttons */
        InjectKey('c',      (held & WPAD_NUNCHUK_BUTTON_C) ? qtrue : qfalse);
        InjectKey(K_MOUSE2, (held & WPAD_NUNCHUK_BUTTON_Z) ? qtrue : qfalse);

        /* Nunchuk stick → WASD (uses calibrated mag/ang) */
        InjectJsWASD(&d->exp.nunchuk.js);

        /* IR pointer → camera */
        InjectIR(d);

    } else {
        /* ── Menu mode ─────────────────────────────────────── */
        InjectKey(K_ENTER,     (held & WPAD_BUTTON_A)    ? qtrue : qfalse);
        InjectKey(K_ESCAPE,    (held & (WPAD_BUTTON_B | WPAD_BUTTON_PLUS)) ? qtrue : qfalse);
        InjectKey(K_UPARROW,   (held & WPAD_BUTTON_UP)   ? qtrue : qfalse);
        InjectKey(K_DOWNARROW, (held & WPAD_BUTTON_DOWN) ? qtrue : qfalse);
        InjectKey(K_LEFTARROW, (held & WPAD_BUTTON_LEFT) ? qtrue : qfalse);
        InjectKey(K_RIGHTARROW,(held & WPAD_BUTTON_RIGHT)? qtrue : qfalse);

        /* Nunchuk stick → cursor */
        InjectJsMouse(&d->exp.nunchuk.js, STICK_SENSITIVITY_F,
                      &s_cursor_ax, &s_cursor_ay);
    }
}

/* ─── Classic Controller handler (same layout as GC) ───────────────────── */
static void ProcessClassic(WPADData *d, qboolean in_game)
{
    u32 held = WPAD_ButtonsHeld(WPAD_CHAN_0);

    if (held & WPAD_CLASSIC_BUTTON_HOME)
        s_home_pressed = qtrue;

    if (in_game) {
        /* ── Game mode ─────────────────────────────────────── */

        /* Left stick + D-pad → WASD */
        InjectJsWASD(&d->exp.classic.ljs);
        InjectKey('w', (held & WPAD_CLASSIC_BUTTON_UP)    ? qtrue : qfalse);
        InjectKey('s', (held & WPAD_CLASSIC_BUTTON_DOWN)  ? qtrue : qfalse);
        InjectKey('a', (held & WPAD_CLASSIC_BUTTON_LEFT)  ? qtrue : qfalse);
        InjectKey('d', (held & WPAD_CLASSIC_BUTTON_RIGHT) ? qtrue : qfalse);

        /* Right stick → camera */
        InjectJsMouse(&d->exp.classic.rjs, LOOK_SENSITIVITY_F,
                      &s_look_ax, &s_look_ay);

        /* Face buttons */
        InjectKey(K_SPACE,  (held & WPAD_CLASSIC_BUTTON_A) ? qtrue : qfalse);
        InjectKey('c',      (held & WPAD_CLASSIC_BUTTON_B) ? qtrue : qfalse);
        InjectKey(']',      (held & WPAD_CLASSIC_BUTTON_X) ? qtrue : qfalse);
        InjectKey('[',      (held & WPAD_CLASSIC_BUTTON_Y) ? qtrue : qfalse);

        /* Triggers → fire.  Accept both digital (ZR/ZL) and analog full-press (FULL_R/L) */
        InjectKey(K_MOUSE1, (held & (WPAD_CLASSIC_BUTTON_ZR | WPAD_CLASSIC_BUTTON_FULL_R))
                            ? qtrue : qfalse);
        InjectKey(K_MOUSE2, (held & (WPAD_CLASSIC_BUTTON_ZL | WPAD_CLASSIC_BUTTON_FULL_L))
                            ? qtrue : qfalse);

        InjectKey(K_ESCAPE, (held & WPAD_CLASSIC_BUTTON_PLUS) ? qtrue : qfalse);

    } else {
        /* ── Menu mode ─────────────────────────────────────── */

        /* Both sticks → cursor */
        InjectJsMouse(&d->exp.classic.ljs, STICK_SENSITIVITY_F,
                      &s_cursor_ax, &s_cursor_ay);
        InjectJsMouse(&d->exp.classic.rjs, STICK_SENSITIVITY_F,
                      &s_look_ax, &s_look_ay);

        InjectKey(K_MOUSE1,  (held & WPAD_CLASSIC_BUTTON_A) ? qtrue : qfalse);
        InjectKey(K_ENTER,   (held & WPAD_CLASSIC_BUTTON_X) ? qtrue : qfalse);
        InjectKey(K_CONSOLE, (held & WPAD_CLASSIC_BUTTON_Y) ? qtrue : qfalse);
        InjectKey(K_ESCAPE,  (held & (WPAD_CLASSIC_BUTTON_B | WPAD_CLASSIC_BUTTON_PLUS))
                             ? qtrue : qfalse);

        InjectKey(K_UPARROW,   (held & WPAD_CLASSIC_BUTTON_UP)    ? qtrue : qfalse);
        InjectKey(K_DOWNARROW, (held & WPAD_CLASSIC_BUTTON_DOWN)  ? qtrue : qfalse);
        InjectKey(K_LEFTARROW, (held & WPAD_CLASSIC_BUTTON_LEFT)  ? qtrue : qfalse);
        InjectKey(K_RIGHTARROW,(held & WPAD_CLASSIC_BUTTON_RIGHT) ? qtrue : qfalse);
    }
}

/* ─── GameCube fallback handler ─────────────────────────────────────────── */
static void ProcessGameCube(qboolean in_game)
{
    u32 held  = PAD_ButtonsHeld(GC_PORT);
    s8  lx    = PAD_StickX(GC_PORT);
    s8  ly    = PAD_StickY(GC_PORT);
    s8  cx    = PAD_SubStickX(GC_PORT);
    s8  cy    = PAD_SubStickY(GC_PORT);
    u8  l_ana = PAD_TriggerL(GC_PORT);
    u8  r_ana = PAD_TriggerR(GC_PORT);

    if (in_game) {
        /* ── Game mode ─────────────────────────────────────── */

        /* Left stick + D-pad → WASD */
        InjectGcStickWASD(lx, ly);
        InjectKey('w', (held & PAD_BUTTON_UP)    ? qtrue : qfalse);
        InjectKey('s', (held & PAD_BUTTON_DOWN)  ? qtrue : qfalse);
        InjectKey('a', (held & PAD_BUTTON_LEFT)  ? qtrue : qfalse);
        InjectKey('d', (held & PAD_BUTTON_RIGHT) ? qtrue : qfalse);

        /* C-stick → camera */
        InjectGcStickMouse(cx, cy, LOOK_SENSITIVITY_F, &s_look_ax, &s_look_ay);

        /* Face buttons */
        InjectKey(K_SPACE,  (held & PAD_BUTTON_A)     ? qtrue : qfalse);
        InjectKey('c',      (held & PAD_BUTTON_B)     ? qtrue : qfalse);
        InjectKey(']',      (held & PAD_BUTTON_X)     ? qtrue : qfalse);
        InjectKey('[',      (held & PAD_BUTTON_Y)     ? qtrue : qfalse);
        InjectKey(K_ENTER,  (held & PAD_TRIGGER_Z)    ? qtrue : qfalse);
        InjectKey(K_ESCAPE, (held & PAD_BUTTON_START) ? qtrue : qfalse);

        /* Analog triggers → fire */
        InjectKey(K_MOUSE1, r_ana > TRIGGER_THRESHOLD ? qtrue : qfalse);
        InjectKey(K_MOUSE2, l_ana > TRIGGER_THRESHOLD ? qtrue : qfalse);

    } else {
        /* ── Menu mode ─────────────────────────────────────── */

        /* Both sticks → cursor */
        InjectGcStickMouse(lx, ly, STICK_SENSITIVITY_F, &s_cursor_ax, &s_cursor_ay);
        InjectGcStickMouse(cx, cy, STICK_SENSITIVITY_F, &s_look_ax,   &s_look_ay);

        InjectKey(K_MOUSE1, (held & (PAD_BUTTON_A | PAD_TRIGGER_Z)) ? qtrue : qfalse);
        InjectKey(K_ENTER,  (held & PAD_BUTTON_X)                   ? qtrue : qfalse);
        InjectKey(K_CONSOLE,(held & PAD_BUTTON_Y)                   ? qtrue : qfalse);
        InjectKey(K_ESCAPE, (held & (PAD_BUTTON_B | PAD_BUTTON_START)) ? qtrue : qfalse);

        InjectKey(K_UPARROW,   (held & PAD_BUTTON_UP)    ? qtrue : qfalse);
        InjectKey(K_DOWNARROW, (held & PAD_BUTTON_DOWN)  ? qtrue : qfalse);
        InjectKey(K_LEFTARROW, (held & PAD_BUTTON_LEFT)  ? qtrue : qfalse);
        InjectKey(K_RIGHTARROW,(held & PAD_BUTTON_RIGHT) ? qtrue : qfalse);
    }
}

/* ─── Public API ────────────────────────────────────────────────────────── */

void Wii_Input_Init(void)
{
    memset(s_key_held, 0, sizeof(s_key_held));
    s_ctrl_type     = CTRL_NONE;
    s_in_game       = qfalse;
    s_home_pressed  = qfalse;
    s_cursor_ax = s_cursor_ay = 0.0f;
    s_look_ax   = s_look_ay   = 0.0f;
    s_ir_ax     = s_ir_ay     = 0.0f;
    s_ir_prev_valid = qfalse;

    WPAD_Init();
    WPAD_SetDataFormat(WPAD_CHAN_0, WPAD_FMT_BTNS_ACC_IR);
    WPAD_SetVRes(WPAD_CHAN_0, 640, 480);

    PAD_Init();

    printf("[input] unified backend: Wiimote+Nunchuk / Classic / GameCube\n");
}

void Wii_Input_Frame(void)
{
    s_home_pressed = qfalse;

    WPAD_ScanPads();
    PAD_ScanPads();

    /* Detect active controller type — Wiimote+extension takes priority over GC */
    ctrl_type_t new_ctrl = CTRL_GAMECUBE;

    WPADData *wd = WPAD_Data(WPAD_CHAN_0);
    if (wd && wd->err == WPAD_ERR_NONE) {
        if (wd->exp.type == WPAD_EXP_NUNCHUK)
            new_ctrl = CTRL_WIIMOTE_NUNCHUK;
        else if (wd->exp.type == WPAD_EXP_CLASSIC)
            new_ctrl = CTRL_CLASSIC;
        /* WPAD_EXP_NONE (bare Wiimote) → fall through to GC */
    }

    /* Release all keys on controller type or game/menu mode change */
    qboolean in_game = (Key_GetCatcher() == 0) ? qtrue : qfalse;
    if (new_ctrl != s_ctrl_type || in_game != s_in_game) {
        ReleaseAllKeys();
        s_ctrl_type = new_ctrl;
        s_in_game   = in_game;
    }

    switch (s_ctrl_type) {
    case CTRL_WIIMOTE_NUNCHUK:
        ProcessWiimoteNunchuk(wd, in_game);
        break;
    case CTRL_CLASSIC:
        ProcessClassic(wd, in_game);
        break;
    case CTRL_GAMECUBE:
    default:
        ProcessGameCube(in_game);
        break;
    }
}

qboolean Wii_Input_HomePressed(void)
{
    return s_home_pressed;
}

void Wii_Input_GenerateEvents(void)
{
    /* Events already injected in Wii_Input_Frame() */
}
